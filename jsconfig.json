{
    "compilerOptions": {
        "checkJs": true,
        "target": "ES2022",
        "module": "ES2022",
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ES2022"
        ],
        "strict": true,
        "allowJs": true,
        "noEmit": true,
        "typeRoots": [
            "./types"
        ]
    },
    "include": [
        "src/**/*.js",
        "types/**/*.d.ts"
    ],
    "exclude": [
        "tools/**/*",
        "documents/**/*"
    ]
}