{
  "manifest_version": 3,
  "name": "ChatGPT View Manager",
  "description": "Adds local navigation and visibility controls to long ChatGPT conversations.",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "src/content/draw.js",
        "src/content/conversationScanner.js",
        "src/content/viewManagerStrings.js",
        "src/content/viewManagerIcons.js",
        "src/content/viewManagerIconButtonFactory.js",
        "src/content/hoverToolbar.js",
        "src/content/informationBar.js",
        "src/content/viewManagerActionsDropdown.js",
        "src/content/viewManagerLocalPersistence.js",
        "src/content/viewManagerNotesManager.js",
        "src/content/viewManagerImportExport.js",
        "src/content/collapsedBlocksManager.js",
        "src/content/content.js"
      ],
      "css": [
        "src/content/content.css",
        "src/content/hoverToolbar.css",
        "src/content/informationBar.css",
        "src/content/collapsedBlocksManager.css",
        "src/content/viewManagerNotes.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
